# --- PORTFOLIO CMS ENVIRONMENT VARIABLES ---

# The secret key used to encrypt the login session tokens. 
# Make this a long, random string in production!
JWT_SECRET=super_secure_random_key_here

# (Railway Specific) 
# If you are using Railway, you must create a persistent Volume and mount it (e.g. to /data).
# Then, uncomment and set the DB_PATH below so your database doesn't reset on every deploy!
# DB_PATH=/data/portfolio.db

# The port the server runs on (usually automatically handled by Railway/Render)
PORT=3000
