# Environment Variables Template
# Copy this file to .env and fill in your details

# The port your server runs on locally (default: 3000)
PORT=3000

# Your Supabase PostgreSQL Connection String (Transaction Pooler or Direct)
# Example: postgresql://postgres:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=""

# Secret key used for signing JWT auth tokens
# Use a strong, random string in production!
JWT_SECRET="super_secret_admin_key_123"
